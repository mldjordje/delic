# Neon (Vercel često injectuje POSTGRES_URL iz integracije)
DATABASE_URL=
# ili eksplicitno:
POSTGRES_URL=

# JWT sesija (min ~32 karaktera)
AUTH_JWT_SECRET=

# OTP email prijava
AUTH_OTP_SALT=
RESEND_API_KEY=
RESEND_FROM=
RESEND_REPLY_TO=

# Javni URL aplikacije (email linkovi, CORS ako treba)
NEXT_PUBLIC_APP_URL=https://tvoj-projekat.vercel.app
# ili APP_URL / NEXT_PUBLIC_SITE_URL — uskladi sa lib/env u bootstrap kodu

# Opciono: Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cron / interni jobovi
CRON_SECRET=

# Opciono: Vercel Blob (slike, PDF)
BLOB_READ_WRITE_TOKEN=

# Zakazivanje (tehnički pregled — 30 min slotovi)
CLINIC_SLOT_MINUTES=30
CLINIC_BOOKING_WINDOW_DAYS=31
