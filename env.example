# Neon (Vercel često injectuje POSTGRES_URL iz integracije)
POSTGRES_URL=
# ili:
DATABASE_URL=

# JWT sesija (min. ~32 karaktera)
AUTH_JWT_SECRET=

# OTP email prijava
AUTH_OTP_SALT=

# Google OAuth (Sign in with Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: override redirect uri for custom domain (prod)
GOOGLE_REDIRECT_URI=https://autodelic.com/api/auth/google/callback

# Resend (slanje OTP i obaveštenja)
RESEND_API_KEY=
RESEND_FROM=Auto Delić <onboarding@resend.dev>
RESEND_REPLY_TO=

# Opciono: obaveštenje admin inbox pri novom terminu
ADMIN_BOOKING_NOTIFY_EMAIL=

# Javni URL (email linkovi, CORS)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# CORS: ako legacy HTML ostane na drugom domenu (cPanel), dodaj origin ovde (zarezom)
# CORS_ALLOWED_ORIGINS=https://stari-sajt.rs,https://www.stari-sajt.rs

# Podrazumevani „traka“ slug (seed)
GARAGE_DEFAULT_EMPLOYEE_SLUG=auto-delic-lane-1

# Radno vreme (fallback ako nema reda u garage_settings)
CLINIC_WORKDAY_START=08:00
CLINIC_WORKDAY_END=17:00
CLINIC_SATURDAY_START=08:00
CLINIC_SATURDAY_END=14:00
CLINIC_SLOT_MINUTES=30
CLINIC_BOOKING_WINDOW_DAYS=31

# Opciono: Vercel Blob
BLOB_READ_WRITE_TOKEN=
